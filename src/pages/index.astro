---
import Container from '../components/layout/Container.astro';
import PostListItem from '../components/post/PostListItem.astro';
import { NOTE_CATEGORY_META } from '../consts';
import { getContestGroups, getLatestPosts, getTaxonomyBuckets } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';

const [latestPosts, tagBuckets, contestGroups] = await Promise.all([
  getLatestPosts(6),
  getTaxonomyBuckets('tags'),
  getContestGroups(),
]);

const stats = [
  { label: 'Latest posts', value: latestPosts.length },
  { label: 'Tracked tags', value: tagBuckets.length },
  { label: 'Contest events', value: contestGroups.length },
];
---

<BaseLayout>
  <Container class="home-shell">
    <section class="brand-hero">
      <span class="brand-hero__eyebrow">CTF Notebook</span>
      <h1>December's Blog</h1>
      <div class="brand-hero__line" aria-hidden="true"></div>
      <div class="hero-actions">
        <a class="button button--primary" href="/blog/">Explore the archive</a>
        <a class="button" href="/search/">Search notes</a>
      </div>
    </section>

    <section class="stats-grid">
      {stats.map((item) => (
        <article class="stat-card">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </article>
      ))}
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Recent Updates</span>
        <h2>Latest writing</h2>
      </div>
      {latestPosts.length > 0 ? (
        <div class="post-list">
          {latestPosts.map((post) => <PostListItem post={post} />)}
        </div>
      ) : (
        <div class="empty-panel">
          <p class="empty-state">还没有公开文章。后续把 `.md` 或 `.mdx` 放进 `src/content/notes` 或 `src/content/contests` 就会自动出现在这里。</p>
        </div>
      )}
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Direction Map</span>
        <h2>Topic areas</h2>
      </div>
      <div class="category-grid">
        {Object.entries(NOTE_CATEGORY_META).map(([slug, meta]) => (
          <a class="category-panel" href={`/categories/${slug}/`}>
            <strong>{meta.label}</strong>
            <p>{meta.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Contest Stream</span>
        <h2>Recent events</h2>
      </div>
      {contestGroups.length > 0 ? (
        <div class="event-grid">
          {contestGroups.slice(0, 3).map((group) => (
            <article class="event-card">
              <strong>{group.contestName}</strong>
              <p>
                {group.items.length} posts · {group.teamName ?? 'team pending'} · {group.rank ?? 'rank pending'}
              </p>
              <a href={group.items[0]?.url}>Open event notes</a>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-panel">
          <p class="empty-state">比赛复盘区现在是空的，等你发布第一篇赛事总结后这里会自动聚合。</p>
        </div>
      )}
    </section>
  </Container>
</BaseLayout>
