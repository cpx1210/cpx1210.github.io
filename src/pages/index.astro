---
import Container from '../components/layout/Container.astro';
import PostListItem from '../components/post/PostListItem.astro';
import { getLatestPosts, getPublishedEntries } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';

const [latestPosts, notes, writeups] = await Promise.all([
  getLatestPosts(6),
  getPublishedEntries('notes'),
  getPublishedEntries('contests'),
]);

const sections = [
  {
    href: '/blog/',
    label: 'Blog',
    count: latestPosts.length,
    description: 'All published posts in one clean stream.',
  },
  {
    href: '/notes/',
    label: 'Notes',
    count: notes.length,
    description: 'Learning records, tooling notes, and long-form writeups.',
  },
  {
    href: '/contests/',
    label: 'Writeup',
    count: writeups.length,
    description: 'Competition reviews and challenge-level solutions.',
  },
];
---

<BaseLayout>
  <Container class="home-shell">
    <section class="brand-hero">
      <span class="brand-hero__eyebrow">CTF Notebook</span>
      <h1>December's Blog</h1>
      <div class="brand-hero__line" aria-hidden="true"></div>
    </section>

    <section class="section-block">
      <div class="category-grid">
        {sections.map((section) => (
          <a class="category-panel" href={section.href}>
            <strong>{section.label}</strong>
            <p>{section.description}</p>
            <span class="meta-pill">{section.count} posts</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Latest</span>
        <h2>Recent writing</h2>
      </div>
      {latestPosts.length > 0 ? (
        <div class="post-list">
          {latestPosts.map((post) => <PostListItem post={post} />)}
        </div>
      ) : (
        <div class="empty-panel">
          <p class="empty-state">还没有公开文章。后续把 `.md` 或 `.mdx` 放进 `src/content/notes` 或 `src/content/contests` 就会自动出现在这里。</p>
        </div>
      )}
    </section>
  </Container>
</BaseLayout>
