---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import {
  getPrevNextPosts,
  getPublishedEntries,
  getReadingTimeText,
  getRelatedPosts,
  toPostSummary,
  type ContestEntry,
} from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getPublishedEntries('contests');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ContestEntry };
const { Content, headings } = await render(entry);
const entries = await getPublishedEntries('contests');
const { newer, older } = getPrevNextPosts(entries, entry.id);
const relatedPosts = await getRelatedPosts(entry, 'contests');
---

<PostLayout
  entry={entry}
  headings={headings}
  readingTime={getReadingTimeText(entry.body)}
  relatedPosts={relatedPosts}
  newerPost={newer ? toPostSummary(newer, 'contests') : undefined}
  olderPost={older ? toPostSummary(older, 'contests') : undefined}
>
  <Content />
</PostLayout>
