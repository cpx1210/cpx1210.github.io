---
import PostListItem from '../../components/post/PostListItem.astro';
import { getCategoryLabel, getPostsByCategory, getTaxonomyBuckets } from '../../lib/content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const categories = await getTaxonomyBuckets('category');
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { categoryLabel: getCategoryLabel(category.label), count: category.count },
  }));
}

const { categoryLabel, count } = Astro.props;
const posts = await getPostsByCategory(Astro.params.category ?? '');
---

<PageLayout title={`Category: ${categoryLabel}`} description={`${count} posts in ${categoryLabel}.`}>
  <p class="page-intro">{count} matching posts.</p>
  <div class="post-list">
    {posts.map((post) => <PostListItem post={post} />)}
  </div>
</PageLayout>
