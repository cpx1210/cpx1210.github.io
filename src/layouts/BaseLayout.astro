---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import '../styles/prose.css';
import '../styles/code.css';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  pageType?: 'website' | 'article';
}

const {
  title,
  description = SITE.description,
  canonicalPath = Astro.url.pathname,
  pageType = 'website',
} = Astro.props as Props;

const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const canonical = new URL(canonicalPath, Astro.site ?? SITE.url).toString();
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#07111f" />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const preferredLight = window.matchMedia('(prefers-color-scheme: light)').matches;
      document.documentElement.dataset.theme = savedTheme ?? (preferredLight ? 'light' : 'dark');
    </script>
  </head>
  <body>
    <SiteHeader currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
