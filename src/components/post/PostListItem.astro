---
import type { PostSummary } from '../../lib/content';
import { formatDate } from '../../lib/utils';
import SectionBadge from '../ui/SectionBadge.astro';
import TagChip from '../ui/TagChip.astro';

interface Props {
  post: PostSummary;
}

const { post } = Astro.props as Props;
---

<article class="post-list-item">
  <div class="post-list-item__main">
    <div class="post-list-item__topline">
      <SectionBadge section={post.section} />
      {post.difficulty && <span class="meta-pill">{post.difficulty}</span>}
    </div>

    <h3 class="post-list-item__title">
      <a href={post.url}>{post.title}</a>
    </h3>

    <p class="post-list-item__description">{post.description}</p>

    <div class="post-list-item__tags">
      {post.tags.slice(0, 5).map((tag) => <TagChip label={tag} />)}
    </div>
  </div>

  <div class="post-list-item__meta">
    <span>{formatDate(post.pubDate)}</span>
    <span>{post.section === 'contests' ? 'Writeup' : 'Notes'}</span>
  </div>
</article>
